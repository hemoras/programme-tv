# Copier ce fichier en ".env" (non versionné) et ajuster les chemins.
#
# Dossier racine contenant les scans, organisés en sous-dossiers par année
# (ex. PAGES_DIR/2001/2001-01-01-Page1.jpg). Utilisé par la commande
# --year pour traiter toutes les pages d'une année en une fois.
PAGES_DIR=F:\programmes-tv\Télé 7 jours\Pages

# Dossier racine contenant les PDF de numéros complets de Télé 7 Jours,
# organisés en sous-dossiers par année (ex. PDF_DIR/2001/2001-07-07.pdf, le
# nom du PDF étant la date du samedi d'ouverture du numéro). Utilisé par
# "npm run index-pdf -- <année>" pour repérer, dans chaque PDF, le numéro de
# page de la première page de programme de chacun des 7 jours.
PDF_DIR=F:\programmes-tv\Télé 7 jours\pdf
